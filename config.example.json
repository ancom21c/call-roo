    "keepalive_hex": "1f1111",
    "keepalive_response_bytes": 3,
    "adapter_name": "hci0,hci1",
    "disabled_adapter_names": [],
    "adapter_reset_after_failures": 5,
    "adapter_reset_cooldown_seconds": 60.0,
